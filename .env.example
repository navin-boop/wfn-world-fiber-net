# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default — works out of the box)
DATABASE_URL="file:./dev.db"
# PostgreSQL (swap when deploying to production)
# DATABASE_URL="postgresql://user:password@localhost:5432/worldfibernet"

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET="your-super-secret-session-key-change-in-production"

# ─── WhatsApp Business Cloud API ─────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_BUSINESS_NUMBER="9779800000000"

# ─── Public env (exposed to browser) ─────────────────────────────────────────
# Used by the floating WhatsApp button (include country code, no +)
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER="9779800000000"

# ─── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://worldfibernet.net.np"
